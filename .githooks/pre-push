#!/usr/bin/env bash
# pre-push hook — Run unit tests before push and block bare --force (D003).

set -euo pipefail

run_unit_tests() {
  if ! command -v bats >/dev/null 2>&1; then
    echo "BLOCKED: bats is required for pre-push unit tests." >&2
    exit 1
  fi

  if ! command -v timeout >/dev/null 2>&1; then
    echo "BLOCKED: timeout is required for pre-push unit tests." >&2
    exit 1
  fi

  if [ ! -d "tests/unit" ]; then
    echo "BLOCKED: tests/unit directory not found." >&2
    exit 1
  fi

  echo "Running unit tests before push..."
  set +e
  timeout 120 bats tests/unit/ --jobs 4 --timing
  test_status=$?
  set -e

  if [ "$test_status" -eq 124 ]; then
    echo "BLOCKED: unit tests exceeded 40 seconds." >&2
    exit 1
  fi

  if [ "$test_status" -ne 0 ]; then
    echo "BLOCKED: unit tests failed. Push aborted." >&2
    exit 1
  fi
}

read_parent_cmdline() {
  if [[ -r "/proc/$PPID/cmdline" ]]; then
    tr '\0' ' ' < "/proc/$PPID/cmdline"
  fi
}

check_force_push_policy() {
  local cmdline
  cmdline="$(read_parent_cmdline)"

  # If we couldn't read cmdline, allow after tests (fail-open for non-Linux).
  if [[ -z "$cmdline" ]]; then
    return 0
  fi

  if echo "$cmdline" | grep -qE -- '--force-with-lease'; then
    return 0
  fi

  if echo "$cmdline" | grep -qE -- '(^| )--force( |$)|(^| )-f( |$)'; then
    echo "BLOCKED: git push --force is forbidden (D003). Use --force-with-lease instead." >&2
    exit 1
  fi
}

main() {
  run_unit_tests
  check_force_push_policy
}

main "$@"
